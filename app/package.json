{
  "name": "vdo-spacial-comms",
  "version": "0.1.0",
  "description": "Spatial binaural intercom via VDO.ninja — per-line HRTF positioning, push-to-talk, Control API",
  "author": {
    "name": "Reynolds Productions",
    "email": "thomasreynolds75@gmail.com"
  },
  "homepage": "https://github.com/ReynoldsProductions/VDO.Spacial.Comms",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/bump-build.js && electron-builder",
    "build:dir": "node scripts/bump-build.js && electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "com.vdo.spacial.comms",
    "productName": "VDO.Spacial.Comms",
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!scripts",
      "!assets/icon-source.png",
      "!assets/*.iconset"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "AudioVideo"
    },
    "dmg": {
      "title": "VDO.Spacial.Comms ${version}"
    }
  }
}
