{
  "name": "vdo-multichan-comms",
  "version": "0.1.3",
  "description": "Multi-channel IP intercom via VDO.ninja + CPAL audio shim",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/bump-build.js && electron-builder",
    "build:dir": "node scripts/bump-build.js && electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "build": {
    "appId": "com.vdo.multichan.comms",
    "productName": "VDO.MultiCh.Comms",
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!scripts",
      "!assets/icon-source.png",
      "!assets/*.iconset"
    ],
    "extraResources": [
      {
        "from": "native/build/Release/coreaudio.node",
        "to": "coreaudio.node"
      }
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ]
    },
    "dmg": {
      "title": "VDO.MultiCh.Comms ${version}"
    }
  }
}
